# ─── Supabase ──────────────────────────────────────────────────────────────────
# Récupérés dans : Project Settings > API (Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# ─── TMDB ──────────────────────────────────────────────────────────────────────
# Récupéré dans : themoviedb.org > Settings > API > API Read Access Token
# Utilisé uniquement côté serveur (API Routes / Server Components)
TMDB_API_READ_TOKEN=your-tmdb-read-access-token
